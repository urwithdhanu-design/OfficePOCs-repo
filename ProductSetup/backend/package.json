{
  "name": "featureflow-ai-backend",
  "version": "1.0.0",
  "description": "AI utilities API for FeatureFlow Product Setup (configuration assistant & smart recommendations)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-catalog": "node scripts/sync-feature-catalog.mjs"
  },
  "keywords": ["featureflow", "product-setup", "ai"],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
